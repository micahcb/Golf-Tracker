# Copy to apps/web/.env.local (never commit real values)
#
# Railway / other hosts: add the same variables in the service "Variables" tab.
# For a Turborepo deploy, either set Root Directory to apps/web or inject env into
# the service that runs `next start` for this app.

# Project URL (this is NOT "Site URL" under Auth — it is your API base, https://<ref>.supabase.co)
# Easiest: open your project → top bar "Connect" (or Project Settings → Connect) → copy Project URL.
# Or: Project Settings → API keys — the Project URL is often shown at the top of that page.
# Fallback: your dashboard URL is .../dashboard/project/<ref>/... — use https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Use the publishable key (recommended) or legacy anon key — not the secret/service_role key.
# Dashboard → Settings → API Keys → Publishable key (or Legacy → anon public)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: Postgres connection URI (Session mode, port 5432) for automatic DDL on deploy.
# Supabase → Project Settings → Database → Connection string → URI.
# When set, `instrumentation.ts` runs CREATE TABLE IF NOT EXISTS + RLS for golf_tracker_preferences.
# The same variable powers POST /api/golf-tracker/ensure-schema (called from the app before DB reads/writes).
# If you see EHOSTUNREACH to an IPv6 address on local dev, try Supabase → Database → Connection string →
# "Session pooler" (host often contains pooler.supabase.com). Avoid Transaction pooler (6543) for DDL.
# Or paste lib/db/bootstrap-schema.ts into the SQL editor once. The app also tries DNS A-record (IPv4) + TLS SNI.
# Do not expose this in the browser; server-side only (e.g. Railway service variables).
DATABASE_URL=

# If you still use legacy keys only:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

